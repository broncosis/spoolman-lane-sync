# Spoolman Lane Sync — configuration
# Copy to .env and edit. The service reads this file on startup.

# Moonraker base URL (no trailing slash)
# Use localhost if the service runs on the same machine as Moonraker.
MOONRAKER_URL=http://localhost:7125

# Spoolman base URL (no trailing slash)
# Use localhost if Spoolman runs on the same machine.
SPOOLMAN_URL=http://localhost:7912

# Moonraker API key — only needed if you have [authorization] enabled
# in moonraker.conf. Leave blank otherwise.
MOONRAKER_API_KEY=

# Log verbosity: DEBUG | INFO | WARNING | ERROR  (default: INFO)
# Set to DEBUG to see every sync detail and WS message.
LOG_LEVEL=INFO
